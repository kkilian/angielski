  "minikursy": [
    { "id": "m1", "tytul": "Co dalej ze mną — powrót z Norwegii", "temat": "Domykanie roboty w Norwegii, powrót do Polski, gdzie zamieszkać (Kraków: pokój/kawalerka/rodzice/inne miasto), pierwszy ruch zawodowy (oferta korepetycji vs własna działalność). Bohater: Jake (amerykański kumpel). Rejestr: codzienny peer. Apka → M5.", "status": "wygenerowany (01-11)" },
    { "id": "m2", "tytul": "Wyjście na swoje", "temat": "Decyzja, żeby ruszyć na swoje (MadreM — własne korepetycje + darmowy kurs matematyki na YouTube): przesądzić sprawę i pójść na całość, postawić kanał i wypluwać treści, tłumaczyć/uczyć na kamerze, i grać z głową (dyscyplina, rozliczalność, pułapka porównań w wieku 27 lat, maska „niby coś robię”). Powrót z Norwegii i wprowadzka do rodziców na „runway”. Bohater: Jake (kumpel, któremu mówisz, że idziesz na swoje). Rejestr: codzienny peer. Oparte na realnej rozmowie Krzyśka.", "status": "w generacji" },
    { "id": "m3", "tytul": "Mieszkanie i codzienność", "temat": "Szukanie mieszkania, przeprowadzka, urzędy, sąsiedzi, rutyna", "status": "szkic" },
